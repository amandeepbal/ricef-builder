<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:tnt="sap.tnt" xmlns:f="sap.f"
    controllerName="com.syntax.ricefbuilder.controller.App">
    <App id="shellApp">
        <Page id="shellPage" showHeader="false" enableScrolling="false">
            <customHeader>
                <f:ShellBar id="shellBar"
                    title="RICEFW Estimator"
                    showNavButton="{appView>/showNavButton}"
                    showMenuButton="{appView>/showToolPage}"
                    menuButtonPressed="onToggleSideNav"
                    navButtonPressed="onShellHome"
                    homeIconPressed="onShellHome"
                    avatarPressed="onUserInfo"
                    showProductSwitcher="false">
                    <f:profile>
                        <Avatar initials="{userInfo>/initials}" displaySize="XS"
                            backgroundColor="Accent6"/>
                    </f:profile>
                    <f:additionalContent>
                        <Button icon="sap-icon://hint" tooltip="App Info" press="onUserInfo" type="Transparent"/>
                    </f:additionalContent>
                </f:ShellBar>
            </customHeader>
            <content>
                <NavContainer id="rootNavContainer">
                    <Page id="launchpadHost" showHeader="false">
                        <NavContainer id="launchpadNavContainer"/>
                    </Page>
                    <Page id="toolPageHost" showHeader="false" enableScrolling="false">
                        <tnt:ToolPage id="toolPage" sideExpanded="false" class="ricefAppShell">
                            <tnt:sideContent>
                                <tnt:SideNavigation id="sideNav" selectedKey="home">
                                    <tnt:NavigationList>
                                        <tnt:NavigationListItem text="Projects" icon="sap-icon://home" key="home" select="onNavHome"/>
                                        <tnt:NavigationListItem text="Admin" icon="sap-icon://settings" key="admin" select="onNavToAdmin"
                                            visible="{userInfo>/isAdmin}">
                                            <tnt:NavigationListItem text="RICEF Types" key="adminRicefTypes" select="onNavAdmin"/>
                                            <tnt:NavigationListItem text="Estimation Grid" key="adminGrid" select="onNavAdmin"/>
                                            <tnt:NavigationListItem text="Blended Rates" key="adminRates" select="onNavAdmin"/>
                                            <tnt:NavigationListItem text="Complexity" key="adminComplexity" select="onNavAdmin"/>
                                            <tnt:NavigationListItem text="Dropdowns" key="adminDropdowns" select="onNavAdmin"/>
                                            <tnt:NavigationListItem text="Sheet Config" key="adminSheetConfig" select="onNavAdmin"/>
                                        </tnt:NavigationListItem>
                                    </tnt:NavigationList>
                                </tnt:SideNavigation>
                            </tnt:sideContent>
                            <tnt:mainContents>
                                <NavContainer id="appNavContainer"/>
                            </tnt:mainContents>
                        </tnt:ToolPage>
                    </Page>
                </NavContainer>
            </content>
        </Page>
    </App>
</mvc:View>
