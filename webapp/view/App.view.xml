<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.f"
    controllerName="com.syntax.ricefbuilder.controller.App">
    <f:ShellBar id="shellBar"
        title="RICEFW Estimator"
        secondTitle="SAP Project Estimation"
        homeIcon="./resources/Syntax-logo.webp"
        showNavButton="{appView>/showNavButton}"
        navButtonPressed="onShellHome"
        homeIconPressed="onShellHome"
        avatarPressed="onUserInfo">
        <f:profile>
            <Avatar initials="{userInfo>/initials}" displaySize="XS"
                backgroundColor="Accent6"/>
        </f:profile>
    </f:ShellBar>
    <NavContainer id="appNavContainer"/>
</mvc:View>
