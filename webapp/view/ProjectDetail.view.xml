<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core"
    controllerName="com.syntax.ricefbuilder.controller.ProjectDetail">
    <Page id="projectPage" title="{viewModel>/title}" showNavButton="true" navButtonPress="onNavBack">
        <headerContent>
            <Button icon="sap-icon://sys-help" tooltip="Help" press="onHelp" type="Transparent"/>
            <Button text="Summary" icon="sap-icon://chart-table-view" press="onNavSummary" type="Transparent"/>
            <Button text="Recalculate All" icon="sap-icon://synchronize" press="onRecalcAll" type="Transparent" visible="{viewModel>/editable}"/>
            <Button text="Take Snapshot" icon="sap-icon://camera" press="onTakeSnapshot" type="Transparent"/>
        </headerContent>
        <content>
<MessageStrip text="This project is outside its active date range and is read-only." type="Warning"
                showIcon="true" visible="{viewModel>/readonly}" class="sapUiSmallMargin"/>
            <MessageStrip id="actionConfirmStrip" visible="false" type="Success" showCloseButton="true" showIcon="true"
                class="actionConfirmStrip sapUiSmallMargin"/>
            <IconTabBar id="sheetTabs" select="onTabSelect" selectedKey="RICEF">
                <!-- Tabs built dynamically from sheet_types -->
            </IconTabBar>

            <!-- RICEF / BI / MIGRATION Items Table -->
            <VBox id="itemsPanel" visible="{viewModel>/showItems}">
                <!-- Orange Grid Group -->
                <Panel headerText="Orange Grid (Vendor)" expandable="true" expanded="false" class="sapUiSmallMargin">
                    <Panel headerText="Control Section (per Week Hours)" expandable="true" expanded="false">
                        <Table id="sheetControlTable" fixedLayout="true">
                            <columns>
                                <Column width="14rem"><Text text="Setting"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="PREP"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="FTS"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="DESIGN"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="BUILD"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="SIT/UAT"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="DEP"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="HYP"/></Column>
                            </columns>
                        </Table>
                    </Panel>
                    <Panel id="orangeGridPanel" headerText="Calculated Effort" expandable="true" expanded="true"
                        expand="onOrangeGridExpand">
                        <core:HTML id="orangeGridHtml" content="&lt;div id='orangeGridContainer'&gt;&lt;/div&gt;"
                            afterRendering="onOrangeGridAfterRendering"/>
                    </Panel>
                </Panel>

                <!-- Blue Grid Group -->
                <Panel headerText="Blue Grid (Customer)" expandable="true" expanded="false" class="sapUiSmallMargin">
                    <Panel headerText="Control Section (per Week Hours)" expandable="true" expanded="false">
                        <Table id="blueControlTable" fixedLayout="true">
                            <columns>
                                <Column width="14rem"><Text text="Setting"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="PREP"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="FTS"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="DESIGN"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="BUILD"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="SIT/UAT"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="DEP"/></Column>
                                <Column hAlign="Center" width="5.5rem"><Text text="HYP"/></Column>
                            </columns>
                        </Table>
                    </Panel>
                    <Panel id="blueGridPanel" headerText="Calculated Effort" expandable="true" expanded="true"
                        expand="onBlueGridExpand">
                        <core:HTML id="blueGridHtml" content="&lt;div id='blueGridContainer'&gt;&lt;/div&gt;"
                            afterRendering="onBlueGridAfterRendering"/>
                    </Panel>
                </Panel>

                <!-- Purple Grid (Staffing Explosion) -->
                <Panel id="purpleGridPanel" headerText="Staffing Explosion (Purple Grid)" expandable="true" expanded="false"
                    class="sapUiSmallMargin" visible="{viewModel>/showItems}" expand="onPurpleGridExpand">
                    <core:HTML id="purpleGridHtml" content="&lt;div id='purpleGridContainer'&gt;&lt;/div&gt;"
                        afterRendering="onPurpleGridAfterRendering"/>
                </Panel>

                <OverflowToolbar class="sapUiSmallMarginTop">
                    <Title text="Items" level="H5"/>
                    <ToolbarSpacer/>
                    <Label text="Status:"/>
                    <Select id="filterStatus" change="onFilterChange" width="8rem">
                        <core:Item key="" text="All"/>
                    </Select>
                    <Label text="Complexity:"/>
                    <Select id="filterComplexity" change="onFilterChange" width="9rem">
                        <core:Item key="" text="All"/>
                    </Select>
                    <Label text="Module:"/>
                    <Select id="filterModule" change="onFilterChange" width="7rem">
                        <core:Item key="" text="All"/>
                    </Select>
                    <SearchField width="14rem" search="onFilterChange" id="searchField"/>
                    <Button text="Export PDF" icon="sap-icon://pdf-attachment" press="onExportPdf" type="Transparent"/>
                    <Button text="Add Item" icon="sap-icon://add" press="onAddItem" type="Emphasized" visible="{viewModel>/editable}"/>
                    <Button text="Delete" icon="sap-icon://delete" press="onDeleteItems" type="Reject" visible="{viewModel>/editable}"/>
                </OverflowToolbar>

                <Table id="itemsTable" mode="{= ${viewModel>/editable} ? 'MultiSelect' : 'None' }" growing="true" growingThreshold="200"
                       sticky="ColumnHeaders" items="{ path: 'items>/', factory: '.itemFactory' }">
                    <columns>
                        <Column width="8rem"><Text text="RICEF #"/></Column>
                        <Column width="10rem"><Text text="Type"/></Column>
                        <Column width="6rem"><Text text="Module"/></Column>
                        <Column minScreenWidth="Tablet"><Text text="Description"/></Column>
                        <Column width="7rem"><Text text="Status"/></Column>
                        <Column width="10rem"><Text text="Classification"/></Column>
                        <Column width="8rem"><Text text="Complexity"/></Column>
                        <Column width="6rem" hAlign="End"><Text text="FUNC Hrs"/></Column>
                        <Column width="6rem" hAlign="End"><Text text="TECH Hrs"/></Column>
                        <Column width="6rem" hAlign="End"><Text text="Total Hrs"/></Column>
                    </columns>
                </Table>
            </VBox>

            <!-- ANALYTICS Dashboard -->
            <VBox id="analyticsPanel" visible="{viewModel>/showAnalytics}" class="sapUiSmallMargin">
                <core:HTML id="analyticsHtml" content="&lt;div id='analyticsContainer'&gt;&lt;/div&gt;"/>
            </VBox>

            <!-- SNAPSHOTS -->
            <VBox id="snapshotsPanel" visible="{viewModel>/showSnapshots}" class="sapUiSmallMargin">
                <Panel headerText="Snapshots">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Saved Snapshots"/>
                            <ToolbarSpacer/>
                            <Button text="Compare with Current" icon="sap-icon://compare" press="onCompareSnapshot" id="compareBtn" type="Emphasized"/>
                        </Toolbar>
                    </headerToolbar>
                    <Table id="snapshotTable" items="{ path: 'snapshots>/' }" mode="SingleSelectMaster">
                        <columns>
                            <Column width="8rem"><Text text="Phase"/></Column>
                            <Column><Text text="Label"/></Column>
                            <Column width="6rem" hAlign="Center"><Text text="Items"/></Column>
                            <Column width="8rem" hAlign="End"><Text text="Total Hours"/></Column>
                            <Column width="12rem"><Text text="Created"/></Column>
                            <Column width="4rem"/>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <Text text="{snapshots>phase}"/>
                                <Text text="{snapshots>label}"/>
                                <ObjectNumber number="{snapshots>total_items}" emphasized="false"/>
                                <ObjectNumber number="{snapshots>total_hours}" unit="h" emphasized="true"/>
                                <Text text="{snapshots>created_at}"/>
                                <Button icon="sap-icon://delete" type="Transparent" press="onDeleteSnapshot"/>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- Compare results rendered here -->
                <core:HTML id="compareHtml" content="&lt;div id='compareContainer'&gt;&lt;/div&gt;"/>
            </VBox>

            <!-- FUNCTIONAL Scope Items -->
            <VBox id="functionalPanel" visible="{viewModel>/showFunctional}" class="sapUiSmallMargin">
                <!-- Distribution / Contingency / Architect — mirrors Excel FUNCTIONAL sheet control section -->
                <Panel headerText="Distribution &amp; Contingency" expandable="true" expanded="true">
                    <Table id="funcControlTable" fixedLayout="true">
                        <columns>
                            <Column width="16rem"><Text text="Setting"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="PREP"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="FTS"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="DESIGN"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="BUILD"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="SIT/UAT"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="DEP"/></Column>
                            <Column hAlign="Center" width="5.5rem"><Text text="HYP"/></Column>
                        </columns>
                        <items>
                            <!-- Distribution Split per Phase (PREP-DEP = 100%, HYP excluded) -->
                            <ColumnListItem>
                                <HBox alignItems="Center" class="sapUiSmallMarginBegin">
                                    <Text text="FUNC Scope - Split per Phase %"/>
                                    <core:Icon src="sap-icon://hint" color="#0854a0" class="inlineHint"
                                        tooltip="How scope item hours distribute across phases. PREP through DEP should sum to 100%. HYP is separate (Extra %)."/>
                                </HBox>
                                <Input value="{ctrl>/funcPhasePct/prep}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/fts}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/design}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/build}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/sit_uat}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/dep}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Text text=""/>
                            </ColumnListItem>
                            <!-- Extra % for Phase (HYP only — applied on top of 100% distribution) -->
                            <ColumnListItem>
                                <HBox alignItems="Center" class="sapUiSmallMarginBegin">
                                    <Text text="Extra % for Phase (HYP)"/>
                                    <core:Icon src="sap-icon://hint" color="#0854a0" class="inlineHint"
                                        tooltip="Applied on top of the 100% distribution — not part of the base split. E.g. 5% HYP adds 5% of each role's total scope hours."/>
                                </HBox>
                                <Text text=""/><Text text=""/><Text text=""/><Text text=""/><Text text=""/><Text text=""/>
                                <Input value="{ctrl>/funcPhasePct/hyp}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                            </ColumnListItem>
                            <!-- % Architect per phase — applied to total functional hours -->
                            <ColumnListItem>
                                <HBox alignItems="Center" class="sapUiSmallMarginBegin">
                                    <Text text="% Architect"/>
                                    <core:Icon src="sap-icon://hint" color="#0854a0" class="inlineHint"
                                        tooltip="Percentage of total functional hours allocated to the architect role, configurable per phase. Applied to the functional scope totals."/>
                                </HBox>
                                <Input value="{ctrl>/funcPhasePct/arch_prep}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/arch_fts}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/arch_design}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/arch_build}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/arch_sit_uat}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/arch_dep}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                                <Input value="{ctrl>/funcPhasePct/arch_hyp}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="func-phase-pct"/></customData></Input>
                            </ColumnListItem>
                            <ColumnListItem>
                                <HBox alignItems="Center" class="sapUiSmallMarginBegin">
                                    <Text text="Contingency (% per Phase)"/>
                                    <core:Icon src="sap-icon://hint" color="#0854a0" class="inlineHint"
                                        tooltip="Additional buffer applied per phase to functional scope hours. Phase_Hours x (1 + Contingency%). HYP typically has 0%."/>
                                </HBox>
                                <Input value="{ctrl>/contingency/prep}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                                <Input value="{ctrl>/contingency/fts}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                                <Input value="{ctrl>/contingency/design}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                                <Input value="{ctrl>/contingency/build}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                                <Input value="{ctrl>/contingency/sit_uat}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                                <Input value="{ctrl>/contingency/dep}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                                <Input value="{ctrl>/contingency/hyp}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onFuncCtrlChange"><customData><core:CustomData key="s" value="contingency"/></customData></Input>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- Scope Config -->
                <Panel headerText="Scope Configuration (Baseline Hours)" expandable="true" expanded="false">
                    <Table id="scopeConfigTable" fixedLayout="true">
                        <columns>
                            <Column hAlign="Center"><Text text="Low"/></Column>
                            <Column hAlign="Center"><Text text="Medium"/></Column>
                            <Column hAlign="Center"><Text text="High"/></Column>
                            <Column hAlign="Center"><Text text="KDD"/></Column>
                            <Column hAlign="Center"><Text text="IP"/></Column>
                            <Column hAlign="Center"><Text text="Multiplier"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <Input value="{scope>/config/low_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeConfigChange"/>
                                <Input value="{scope>/config/medium_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeConfigChange"/>
                                <Input value="{scope>/config/high_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeConfigChange"/>
                                <Input value="{scope>/config/kdd_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeConfigChange"/>
                                <Input value="{scope>/config/ip_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeConfigChange"/>
                                <Input value="{scope>/config/complexity_multiplier}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeConfigChange"/>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- Scope Items -->
                <Panel headerText="Functional Scope Items" expandable="true" expanded="true">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Scope Items by Role" level="H5"/>
                            <ToolbarSpacer/>
                            <Button text="Add Role" icon="sap-icon://add" press="onAddScopeItem" type="Emphasized" visible="{viewModel>/editable}"/>
                        </Toolbar>
                    </headerToolbar>
                    <Table id="scopeTable" items="{ path: 'scope>/items' }" sticky="ColumnHeaders">
                        <columns>
                            <Column width="12rem"><Text text="Func Role"/></Column>
                            <Column width="12rem"><Text text="Line of Business"/></Column>
                            <Column hAlign="Center" width="5rem"><Text text="Low"/></Column>
                            <Column hAlign="Center" width="5rem"><Text text="Medium"/></Column>
                            <Column hAlign="Center" width="5rem"><Text text="High"/></Column>
                            <Column hAlign="Center" width="6rem"><Text text="V.High Hrs"/></Column>
                            <Column hAlign="Center" width="6rem"><Text text="Local. Hrs"/></Column>
                            <Column hAlign="Center" width="5rem"><Text text="KDD"/></Column>
                            <Column hAlign="Center" width="5rem"><Text text="IP"/></Column>
                            <Column hAlign="End" width="6rem"><Text text="Total Hrs"/></Column>
                            <Column width="3rem"/>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <Select selectedKey="{scope>func_role}" items="{ path: 'funcRoles>/' }" enabled="{viewModel>/editable}" change="onScopeItemChange" width="100%">
                                    <core:Item key="{funcRoles>value}" text="{funcRoles>value}"/>
                                </Select>
                                <Input value="{scope>lob}" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>low_count}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>medium_count}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>high_count}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>very_high_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>localization_hours}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>kdd_count}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <Input value="{scope>ip_count}" type="Number" textAlign="Center" editable="{viewModel>/editable}" change="onScopeItemChange"/>
                                <ObjectNumber number="{scope>total_hours}" unit="h" emphasized="true"/>
                                <Button icon="sap-icon://delete" type="Reject" press="onDeleteScopeItem" visible="{viewModel>/editable}"/>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- Orange Grid (Functional Effort) -->
                <Panel id="funcOrangeGridPanel" headerText="Orange Grid" expandable="true" expanded="true" class="sapUiTinyMarginTop">
                    <core:HTML id="funcOrangeGridHtml" content="&lt;div id='funcOrangeGridContainer'&gt;&lt;/div&gt;"
                        afterRendering="onFuncOrangeGridAfterRendering"/>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
