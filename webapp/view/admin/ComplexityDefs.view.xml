<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core"
    controllerName="com.syntax.ricefbuilder.controller.admin.ComplexityDefs">
    <Page title="Complexity Definitions" showNavButton="true" navButtonPress="onNavBack">
        <headerContent>
            <Button icon="sap-icon://sys-help" tooltip="Help" press="onHelp" type="Transparent"/>
        </headerContent>
        <content>
            <MessageStrip text="Values are calculated from the Estimation Grid (total functional and technical hours per classification and complexity). Edit the grid to change these values."
                type="Information" showIcon="true" class="sapUiSmallMarginBottom"/>

            <IconTabBar id="teamTabs" select="onTeamSelect" selectedKey="DEV">
                <items>
                    <IconTabFilter key="DEV" text="DEV" icon="sap-icon://developer-scenario"/>
                    <IconTabFilter key="BI" text="BI" icon="sap-icon://business-objects-experience"/>
                    <IconTabFilter key="MIGRATION" text="Migration" icon="sap-icon://database"/>
                </items>
            </IconTabBar>

            <Table id="defsTable" items="{ path: 'defs>/' }">
                <columns>
                    <Column width="14rem"><Text text="Classification"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="FUNC V.Low"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="FUNC Low"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="FUNC Med"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="FUNC High"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="FUNC V.High"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="TECH V.Low"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="TECH Low"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="TECH Med"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="TECH High"/></Column>
                    <Column hAlign="Center" width="5.5rem"><Text text="TECH V.High"/></Column>
                    <Column width="3rem"/>
                </columns>
                <items>
                    <ColumnListItem press="onRowPress"
                        type="{= ${defs>factors}.length > 0 ? 'Navigation' : 'Inactive' }"
                        highlight="{= ${defs>factors}.length > 0 ? 'Information' : 'None' }">
                        <Text text="{defs>_classificationKey}" wrapping="false"/>
                        <ObjectNumber number="{defs>func_very_low}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>func_low}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>func_medium}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>func_high}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>func_very_high}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>tech_very_low}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>tech_low}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>tech_medium}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>tech_high}" unit="h" textAlign="Center"/>
                        <ObjectNumber number="{defs>tech_very_high}" unit="h" textAlign="Center"/>
                        <core:Icon src="sap-icon://decision" color="Positive"
                            visible="{= ${defs>factors}.length > 0 }"
                            tooltip="Complexity factors available — click to view"/>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
