<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m"
    controllerName="com.syntax.ricefbuilder.controller.Home">
    <Page title="Projects" id="homePage">
        <headerContent>
            <Button icon="sap-icon://sys-help" tooltip="Help" press="onHelp" type="Transparent"/>
            <Button text="New Project" icon="sap-icon://add" press="onCreateProject" type="Emphasized"/>
        </headerContent>
        <content>
            <Table id="projectTable" items="{ path: 'projects>/' }"
                noDataText="No projects yet. Create your first estimation project to get started."
                growing="true" growingThreshold="50" sticky="ColumnHeaders">
                <columns>
                    <Column width="8rem"><Text text="Project #"/></Column>
                    <Column><Text text="Description"/></Column>
                    <Column width="6rem" hAlign="Center"><Text text="Currency"/></Column>
                    <Column width="8rem"><Text text="Start"/></Column>
                    <Column width="8rem"><Text text="End"/></Column>
                    <Column width="5rem" hAlign="Center"><Text text="Items"/></Column>
                    <Column width="9rem"><Text text="Config Version"/></Column>
                    <Column width="8rem" hAlign="Center"><Text text="Actions"/></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onProjectPress">
                        <Text text="{projects>project_number}"/>
                        <HBox>
                            <Text text="{projects>description}"/>
                            <ObjectStatus text="Read-Only" state="Warning" visible="{projects>is_readonly}" class="sapUiTinyMarginBegin"/>
                        </HBox>
                        <Text text="{projects>currency}"/>
                        <Text text="{projects>start_date}"/>
                        <Text text="{projects>end_date}"/>
                        <ObjectNumber number="{projects>item_count}" emphasized="false"/>
                        <Text text="{projects>config_version_name}"/>
                        <HBox>
                            <Button icon="sap-icon://edit" tooltip="Edit" type="Transparent" press="onEditProject"/>
                            <Button icon="sap-icon://copy" tooltip="Copy as Template" type="Transparent" press="onCopyProject"/>
                            <Button icon="sap-icon://delete" tooltip="Delete" type="Transparent" press="onDeleteProject"/>
                        </HBox>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
