<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout"
    controllerName="com.syntax.ricefbuilder.controller.Launchpad">
    <Page showHeader="false" class="launchpadPage" enableScrolling="true">
        <content>
            <VBox class="sapUiResponsiveMargin">
                <Title text="Home" level="H3" class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>
                <HBox wrap="Wrap" class="launchpadTiles">
                    <GenericTile header="Projects" subheader="Create and manage estimation projects"
                        frameType="OneByOne" press="onTilePress" class="launchpadTile sapUiTinyMarginEnd sapUiTinyMarginBottom">
                        <customData><core:CustomData key="target" value="home"/></customData>
                        <TileContent>
                            <ImageContent src="sap-icon://project-definition-triangle-2"/>
                        </TileContent>
                    </GenericTile>
                    <GenericTile id="adminTile" header="Administration" subheader="Configuration, rates and dropdowns"
                        frameType="OneByOne" press="onTilePress" class="launchpadTile sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        visible="{userInfo>/isAdmin}">
                        <customData><core:CustomData key="target" value="admin"/></customData>
                        <TileContent>
                            <ImageContent src="sap-icon://settings"/>
                        </TileContent>
                    </GenericTile>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
